# CaseMgr Channel Server Configuration
# Copy to .env and fill in your values

# Required: CaseMgr API token (create via tokens-create in CaseMgr)
CASEMGR_TOKEN=casemgr_your_token_here

# Optional: CaseMgr MCP endpoint (default: production)
# CASEMGR_URL=https://casemgr.systems/mcp
# CASEMGR_URL=https://qa.casemgr.systems/mcp
# CASEMGR_URL=http://localhost:4080/mcp

# Optional: Poll interval in milliseconds (default: 30000 = 30 seconds)
# POLL_INTERVAL_MS=30000
